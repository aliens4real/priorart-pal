# Variables prefixed VITE_ are inlined into the client bundle at build time.
# NEVER put secrets here — these end up shipped to the browser.

VITE_API_BASE_URL=http://localhost:8000
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_HOSTED_UI_DOMAIN=https://priorart-pal-mk-auth.auth.us-east-1.amazoncognito.com
