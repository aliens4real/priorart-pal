# Local dev only. Production reads from Secrets Manager via App Runner.
# Copy to .env and fill in values. .env is gitignored — never commit.

PAP_ENV=dev
PAP_LOG_LEVEL=DEBUG

# AI provider keys — leave empty until needed; Phase 2 will exercise these.
PAP_VOYAGE_API_KEY=
PAP_COHERE_API_KEY=
PAP_ANTHROPIC_API_KEY=

# Local Postgres for dev. Phase 2 stands this up via docker-compose.
PAP_DATABASE_URL=postgresql+psycopg://priorart_pal_app:dev@localhost:5432/priorart_pal
